# ─────────────────────────────────────────────────────────
#  EduPath AI — Backend Environment Variables
# ─────────────────────────────────────────────────────────

# PostgreSQL connection string
# Options (all have free tiers):
#   Neon.tech     → postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/edupath?sslmode=require
#   Supabase      → postgresql://postgres:[pass]@db.[ref].supabase.co:5432/postgres
#   Render Postgres → postgresql://user:pass@dpg-xxx.oregon-postgres.render.com/edupath
#   Railway       → postgresql://postgres:[pass]@containers-us-west-xxx.railway.app:xxxx/railway
DATABASE_URL=postgresql://user:password@host:5432/edupath

# JWT
JWT_SECRET=replace_with_a_random_64_character_string_here_xxxxxxxxxxx
JWT_EXPIRE=30d

# Google Gemini — free key from https://aistudio.google.com
GEMINI_API_KEY=AIzaSy_your_gemini_key_here
OPENAI_API_KEY=sk-your_openai_key_here

# CORS — set to your deployed Vercel frontend URL in production
FRONTEND_URL=http://localhost:3000

PORT=5000
NODE_ENV=development

# Google OAuth Client ID
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
